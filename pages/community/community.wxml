<view class="community-page">
  <view class="status-bar">9:41</view>
  <view class="nav-bar">社区分享</view>
  
  <view class="tab-header">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      <text>美好瞬间</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      <text>生活灵感</text>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <block wx:if="{{activeTab === 0}}">
      <view class="moment-card" wx:for="{{moments}}" wx:key="id">
        <view class="moment-header">
          <view class="avatar">{{item.avatar}}</view>
          <view class="user-info">
            <text class="username">{{item.username}}</text>
            <text class="time">{{item.time}}</text>
          </view>
        </view>
        <image class="moment-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="moment-content">{{item.content}}</view>
        <view class="moment-actions">
          <view class="action-item" bindtap="likeMoment" data-id="{{item.id}}">
            <text class="action-icon">❤️</text>
            <text class="action-text">{{item.likes}}</text>
          </view>
          <view class="action-item">
            <text class="action-icon">💬</text>
            <text class="action-text">{{item.comments}}</text>
          </view>
          <view class="action-item" bindtap="shareMoment" data-id="{{item.id}}">
            <text class="action-icon">🔗</text>
            <text class="action-text">分享</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:if="{{activeTab === 1}}">
      <view class="inspiration-card" wx:for="{{inspirations}}" wx:key="id">
        <view class="inspiration-header">
          <text class="inspiration-icon">{{item.icon}}</text>
          <text class="inspiration-title">{{item.title}}</text>
        </view>
        <view class="inspiration-content">
          <view class="inspiration-item" wx:for="{{item.items}}" wx:key="index" wx:for-item="item">
            <text>{{item}}</text>
          </view>
        </view>
        <view class="inspiration-footer">
          <text class="inspiration-tag" wx:for="{{item.tags}}" wx:key="index">#{{item}}</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="tab-bar">
    <view class="tab-item" bindtap="navigateTo" data-url="/pages/index/index">
      <view class="tab-icon"></view>
      <text>发现</text>
    </view>
    <view class="tab-item active" bindtap="navigateTo" data-url="/pages/community/community">
      <view class="tab-icon"></view>
      <text>社区</text>
    </view>
    <view class="tab-item" bindtap="navigateTo" data-url="/pages/profile/profile">
      <view class="tab-icon"></view>
      <text>我的</text>
    </view>
  </view>
</view>