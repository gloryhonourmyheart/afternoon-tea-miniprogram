.container {
  padding-bottom: 120rpx;
}

.hero-section {
  margin: 0 -20rpx;
  margin-bottom: 40rpx;
}

.hero-bg {
  background: linear-gradient(rgba(255,240,245,0.85), rgba(255,240,245,0.85)), 
              url('https://i.postimg.cc/Z5JqqZ9x/mmexport1778250197075.jpg') center center / cover no-repeat;
  padding: 60rpx 40rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 40rpx;
}

.join-btn {
  background: linear-gradient(135deg, #FF9BB3 0%, #FFB6C1 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999999;
  display: block;
}

.activity-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.activity-card {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.15);
}

.card-image {
  width: 100%;
  height: 240rpx;
}

.card-body {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #FF9BB3;
  background: rgba(255, 182, 193, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.participants {
  font-size: 22rpx;
  color: #999999;
}

.price {
  font-size: 26rpx;
  color: #FF9BB3;
  font-weight: 600;
}

.value-list {
  display: flex;
  justify-content: space-between;
}

.value-card {
  width: calc(33.33% - 14rpx);
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 182, 193, 0.1);
}

.value-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 182, 193, 0.15);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 16rpx;
}

.icon-text {
  font-size: 36rpx;
}

.value-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.value-desc {
  font-size: 22rpx;
  color: #999999;
  display: block;
}