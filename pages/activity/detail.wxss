.container {
  min-height: 100vh;
  background: #FFF0F5;
}

.detail-header {
  position: relative;
}

.detail-image {
  width: 100%;
  height: 400rpx;
}

.detail-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  padding: 60rpx 30rpx 30rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.detail-content {
  background: #ffffff;
  margin: -20rpx 20rpx 20rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.info-section {
  display: flex;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-icon {
  font-size: 28rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 182, 193, 0.1);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.price-label {
  font-size: 26rpx;
  color: #999999;
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF9BB3;
}

.participants {
  font-size: 24rpx;
  color: #999999;
  margin-left: auto;
}

.tags-section {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.tag {
  font-size: 24rpx;
  color: #FF9BB3;
  background: rgba(255, 182, 193, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.desc-section {
  margin-bottom: 30rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.schedule-section {
  margin-bottom: 30rpx;
}

.schedule-list {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 20rpx;
}

.schedule-item {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-time {
  font-size: 26rpx;
  color: #FF9BB3;
  font-weight: 500;
  min-width: 100rpx;
}

.schedule-desc {
  font-size: 26rpx;
  color: #666666;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border: 2rpx solid #FF9BB3;
  border-radius: 16rpx;
  background: #ffffff;
}

.btn-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #FF9BB3;
}

.book-btn {
  flex: 2;
  background: linear-gradient(135deg, #FF9BB3 0%, #FFB6C1 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}