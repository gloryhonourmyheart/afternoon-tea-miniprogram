<view class="membership-page">
  <view class="status-bar">9:41</view>
  <view class="nav-bar">会员中心</view>
  
  <scroll-view scroll-y class="content">
    <view class="vip-card">
      <view class="vip-bg"></view>
      <view class="vip-content">
        <view class="vip-header">
          <view class="vip-badge">
            <text class="vip-icon">{{vipInfo.icon}}</text>
            <text class="vip-level">{{vipInfo.levelName}}</text>
          </view>
          <view class="vip-expire">有效期至 {{vipInfo.expireDate}}</view>
        </view>
        
        <view class="vip-info">
          <view class="points-section">
            <text class="points-value">{{vipInfo.points}}</text>
            <text class="points-label">当前积分</text>
          </view>
          <view class="progress-section">
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{progress}}%"></view>
            </view>
            <text class="progress-text">距离{{nextLevelName}}还需 {{neededPoints}} 积分</text>
          </view>
        </view>

        <button class="vip-btn" bindtap="upgradeVIP">{{upgradeBtnText}}</button>
      </view>
    </view>

    <view class="quick-actions">
      <view class="action-item" bindtap="handleCheckIn">
        <view class="action-icon {{checkedIn ? 'checked' : ''}}">📅</view>
        <text class="action-name">{{checkedIn ? '已签到' : '每日签到'}}</text>
        <text class="action-desc">{{checkedIn ? '明天再来' : '+10积分'}}</text>
      </view>
      <view class="action-item" bindtap="goToMall">
        <view class="action-icon">🎁</view>
        <text class="action-name">积分商城</text>
        <text class="action-desc">兑换好礼</text>
      </view>
      <view class="action-item" bindtap="inviteFriends">
        <view class="action-icon">👥</view>
        <text class="action-name">邀请好友</text>
        <text class="action-desc">+50积分</text>
      </view>
      <view class="action-item" bindtap="viewBenefits">
        <view class="action-icon">📋</view>
        <text class="action-name">权益说明</text>
        <text class="action-desc">查看详情</text>
      </view>
    </view>

    <view class="benefits-section">
      <view class="section-title">
        <text class="section-icon">🎁</text>
        <text>专属权益</text>
        <text class="section-more" bindtap="viewBenefits">查看全部 ›</text>
      </view>
      <view class="benefits-grid">
        <view class="benefit-item" wx:for="{{benefits}}" wx:key="name" bindtap="showBenefitDetail" data-index="{{index}}">
          <view class="benefit-icon">{{item.icon}}</view>
          <text class="benefit-name">{{item.name}}</text>
          <text class="benefit-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="level-section">
      <view class="section-title">
        <text class="section-icon">⭐</text>
        <text>会员等级</text>
      </view>
      <view class="level-list">
        <view class="level-item {{item.status}}" wx:for="{{levels}}" wx:key="name">
          <view class="level-dot {{item.status}}"></view>
          <view class="level-info">
            <text class="level-name">{{item.name}}</text>
            <text class="level-benefit">{{item.benefit}}</text>
          </view>
          <view class="level-status {{item.status}}">
            <text wx:if="{{item.status === 'completed'}}">✓ 已达成</text>
            <text wx:elif="{{item.status === 'current'}}">当前</text>
            <text wx:else>🔒</text>
          </view>
        </view>
      </view>
    </view>

    <view class="history-section">
      <view class="section-title">
        <text class="section-icon">📝</text>
        <text>积分记录</text>
        <text class="section-more" bindtap="viewAllHistory">查看全部 ›</text>
      </view>
      <view class="history-list">
        <view class="history-item" wx:for="{{history}}" wx:key="time">
          <view class="history-icon {{item.type}}">{{item.type === 'add' ? '➕' : '➖'}}</view>
          <view class="history-info">
            <text class="history-title">{{item.title}}</text>
            <text class="history-time">{{item.time}}</text>
          </view>
          <view class="history-points {{item.type}}">{{item.points > 0 ? '+' : ''}}{{item.points}}</view>
        </view>
      </view>
    </view>

    <view class="invite-section">
      <view class="invite-card">
        <view class="invite-content">
          <view class="invite-title">邀请好友得积分</view>
          <view class="invite-desc">每邀请一位好友注册，双方各得50积分</view>
          <button class="invite-btn" bindtap="inviteFriends">立即邀请</button>
        </view>
        <view class="invite-icon">🎁</view>
      </view>
    </view>
  </scroll-view>

  <view class="tab-bar">
    <view class="tab-item" bindtap="navigateTo" data-url="/pages/index/index">
      <view class="tab-icon"></view>
      <text>发现</text>
    </view>
    <view class="tab-item" bindtap="navigateTo" data-url="/pages/community/community">
      <view class="tab-icon"></view>
      <text>社区</text>
    </view>
    <view class="tab-item active" bindtap="navigateTo" data-url="/pages/profile/profile">
      <view class="tab-icon"></view>
      <text>我的</text>
    </view>
  </view>

  <view class="modal {{showModal ? 'active' : ''}}" bindtap="hideModal">
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-header">
        <text class="modal-title">{{modalTitle}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      <view class="modal-body">
        <text>{{modalContent}}</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideModal">取消</button>
        <button class="modal-btn confirm" bindtap="confirmModal">确定</button>
      </view>
    </view>
  </view>
</view>